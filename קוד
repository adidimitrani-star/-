    { front: "תאי זיכרון", back: "לימפוציטים ארוכי-חיים המגיבים במהירות בחשיפה חוזרת לאנטיגן.", chapter: "פרק 4 – מערכת החיסון" },
    { front: "חיסון פעיל", back: "הגוף מייצר בעצמו נוגדנים ותאי זיכרון לאחר חשיפה לאנטיגן.", chapter: "פרק 4 – מערכת החיסון" },
    { front: "חיסון סביל", back: "מתן נוגדנים מוכנים (למשל סרום) ללא יצירת זיכרון חיסוני משמעותי.", chapter: "פרק 4 – מערכת החיסון" },

    // כללי – גנטיקה
    { front: "גנום", back: "כלל החומר הגנטי באורגניזם או בווירוס.", chapter: "כללי – גנטיקה" },
    { front: "מוטציה", back: "שינוי ברצף הנוקלאוטידים של הדנ\"א.", chapter: "כללי – גנטיקה" },
    { front: "מוטציית נקודה", back: "שינוי בבסיס אחד או בזוג בסיסים אחד.", chapter: "כללי – גנטיקה" },
    { front: "מוטציית היסט (Frameshift)", back: "הכנסה או החסרה של נוקלאוטידים המשנה את מסגרת הקריאה.", chapter: "כללי – גנטיקה" },
    { front: "מוטציה שקטה", back: "מוטציה שאינה משנה את רצף החלבון.", chapter: "כללי – גנטיקה" },
    { front: "מוטציית מיסנס", back: "מוטציה המשנה חומצה אמינית אחת בחלבון.", chapter: "כללי – גנטיקה" },
    { front: "מוטציית נונסנס", back: "מוטציה ההופכת קודון לחומצה אמינית לקודון סיום.", chapter: "כללי – גנטיקה" },
    { front: "דוגמת היסוד (Central dogma)", back: "DNA → RNA → חלבון.", chapter: "כללי – ביטוי גנים" },

    // כללי – ביולוגיה של התא
    { front: "דיפוזיה", back: "תנועה פסיבית של חלקיקים מריכוז גבוה לנמוך.", chapter: "פרק 1 – מעבר חומרים" },
    { front: "אוסמוזה", back: "דיפוזיה של מים דרך קרום בררני.", chapter: "פרק 1 – מעבר חומרים" },
    { front: "העברה אקטיבית", back: "מעבר חומרים נגד מפל הריכוז בעזרת אנרגיה (ATP).", chapter: "פרק 1 – מעבר חומרים" },
    { front: "אפופטוזיס", back: "מוות תאי מתוכנן.", chapter: "כללי – ביולוגיה של התא" },
    { front: "נקרוזיס", back: "מוות תאי לא מבוקר בעקבות פגיעה.", chapter: "כללי – ביולוגיה של התא" }
  ];

  // ---------- לוגיקת מבחן ----------

  const quizContainer = document.getElementById('quizContainer');
  const submitQuizBtn = document.getElementById('submitQuiz');
  const newQuizBtn = document.getElementById('newQuiz');
  const scoreDiv = document.getElementById('score');

  let currentQuizQuestions = [];

  function shuffleArray(arr) {
    for (let i = arr.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [arr[i], arr[j]] = [arr[j], arr[i]];
    }
  }

  function generateRandomQuiz() {
    scoreDiv.textContent = "";
    quizContainer.innerHTML = "";
    const questionsCopy = [...questionsBank];
    shuffleArray(questionsCopy);
    currentQuizQuestions = questionsCopy.slice(0, 25); // 25 שאלות רנדומליות

    currentQuizQuestions.forEach((q, index) => {
      const qDiv = document.createElement('div');
      qDiv.className = 'question';

      const title = document.createElement('h3');
      title.textContent = `שאלה ${index + 1}: ${q.text}`;
      qDiv.appendChild(title);

      const answersDiv = document.createElement('div');
      answersDiv.className = 'answers';

      q.options.forEach((opt, i) => {
        const id = `q${index}_opt${i}`;
        const label = document.createElement('label');
        const input = document.createElement('input');
        input.type = 'radio';
        input.name = `q${index}`;
        input.value = i;
        input.id = id;
        label.setAttribute('for', id);
        label.appendChild(input);
        label.appendChild(document.createTextNode(opt));
        answersDiv.appendChild(label);
      });

      qDiv.appendChild(answersDiv);
      quizContainer.appendChild(qDiv);
    });
  }

  function calculateScore() {
    let correctCount = 0;
    currentQuizQuestions.forEach((q, index) => {
      const selected = document.querySelector(`input[name="q${index}"]:checked`);
      if (selected && parseInt(selected.value, 10) === q.correct) {
        correctCount++;
      }
    });
    const totalQuestions = currentQuizQuestions.length;
    const points = correctCount * 4;
    const maxPoints = totalQuestions * 4;
    const grade = (points / maxPoints) * 100;
    scoreDiv.textContent = `ענית נכון על ${correctCount} מתוך ${totalQuestions}. הציון שלך: ${grade.toFixed(1)} / 100`;
  }

  submitQuizBtn.addEventListener('click', calculateScore);
  newQuizBtn.addEventListener('click', generateRandomQuiz);

  // ---------- לוגיקת כרטיסיות ----------

  const flashcardsContainer = document.getElementById('flashcardsContainer');

  function renderFlashcards() {
    flashcardsContainer.innerHTML = "";
    flashcards.forEach(cardData => {
      const wrapper = document.createElement('div');
      wrapper.className = 'card-wrapper';

      const card = document.createElement('div');
      card.className = 'card';

      const inner = document.createElement('div');
      inner.className = 'card-inner';

      const front = document.createElement('div');
      front.className = 'card-face card-front';
      front.textContent = cardData.front;

      const back = document.createElement('div');
      back.className = 'card-face card-back';
      back.textContent = cardData.back;

      inner.appendChild(front);
      inner.appendChild(back);
      card.appendChild(inner);

      card.addEventListener('click', () => {
        card.classList.toggle('flipped');
      });

      const chapter = document.createElement('div');
      chapter.className = 'card-chapter';
      chapter.textContent = `פרק: ${cardData.chapter}`;

      wrapper.appendChild(card);
      wrapper.appendChild(chapter);
      flashcardsContainer.appendChild(wrapper);
    });
  }

  // ---------- טאבים ----------

  const quizTab = document.getElementById('quizTab');
  const flashcardsTab = document.getElementById('flashcardsTab');
  const quizSection = document.getElementById('quizSection');
  const flashcardsSection = document.getElementById('flashcardsSection');

  quizTab.addEventListener('click', () => {
    quizTab.classList.add('active');
    flashcardsTab.classList.remove('active');
    quizSection.classList.add('active');
    flashcardsSection.classList.remove('active');
  });

  flashcardsTab.addEventListener('click', () => {
    flashcardsTab.classList.add('active');
    quizTab.classList.remove('active');
    flashcardsSection.classList.add('active');
    quizSection.classList.remove('active');
  });

  // ---------- התחלה ----------

  generateRandomQuiz();
  renderFlashcards();
</script>
</body>
</html>
